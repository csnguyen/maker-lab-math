# Upstash Redis — auto-injected by Vercel after you connect the integration
# (copy these from Vercel dashboard → your project → Settings → Environment Variables)
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Set to "true" to route frontend API calls to /api/progress instead of the localStorage mock
# Set automatically on Vercel deployments; leave "false" for local dev without credentials
VITE_USE_API=true
